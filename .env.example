TELEGRAM_BOT_TOKEN=put_your_bot_token_here
BOT_SECRET_KEY=replace_with_a_long_random_secret
BOT_MACHINE_NAME=
ALLOWED_TELEGRAM_IDS=
ALLOWED_TELEGRAM_IDS_FILE=./data/allowed-telegram-ids.txt
STARTUP_NOTIFY=true
IHR_STATUS_CHECK_INTERVAL_MINUTES=5
HEARTBEAT_URL=
HEARTBEAT_INTERVAL_MINUTES=5
BOT_LOCK_PORT=47831
IHR_BASE_URL=https://ihr.ipos.vn
IHR_LOGIN_PATH=/System/Login
IHR_CHECKIN_PATH=/Hrm/CheckInOut_Online
HEADLESS=true
ACTION_TIMEOUT_MS=45000
IHR_TRANSPORT=http
IHR_LOCALE=vi-VN
IHR_TIMEZONE=Asia/Ho_Chi_Minh
# Optional geolocation if IHR asks browser location.
# Bot HTTP se tu reverse-geocode cap toa do nay thanh dia chi de luu vao ADRRESS_MAP.
IHR_GEO_LAT=21.0381
IHR_GEO_LNG=105.8147

# WireGuard VPN control (Windows only). Dien ten tunnel chinh xac nhu hien thi trong WireGuard app.
# Vi du: WG_TUNNEL_NAME=iPOS.vn-HaVanTam
# De trong neu khong can tinh nang nay.
# Luu y: Bot can quyen Administrator de bat/tat VPN.
WG_TUNNEL_NAME=
# Duong dan den file .conf neu khac mac dinh (C:\Program Files\WireGuard\Data\Configurations\<tunnel>.conf)
WG_CONF_PATH=
